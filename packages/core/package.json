{
  "name": "@vibedcoder/invespro-core",
  "version": "0.2.1",
  "description": "Core engine for investment profiling and portfolio allocation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vibedcoder/invespro.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/vibedcoder/invespro/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/vibedcoder/invespro/issues"
  },
  "keywords": [
    "investment",
    "risk-profile",
    "asset-allocation",
    "zen-engine",
    "gorules",
    "decision-engine"
  ],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc -b --emitDeclarationOnly",
    "lint": "eslint .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@gorules/zen-engine": "^0.54.0",
    "@vibedcoder/invespro-types": "^0.1.1",
    "csv-parse": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@invespro/eslint-config": "workspace:*",
    "@invespro/tsconfig": "workspace:*",
    "@types/node": "^25.9.3",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
