{
  "name": "@vibedcoder/invespro-hono",
  "version": "0.2.0",
  "description": "Hono REST adapter for investment profiling and portfolio allocation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vibedcoder/invespro.git",
    "directory": "packages/hono"
  },
  "homepage": "https://github.com/vibedcoder/invespro/tree/main/packages/hono#readme",
  "bugs": {
    "url": "https://github.com/vibedcoder/invespro/issues"
  },
  "keywords": [
    "investment",
    "risk-profile",
    "asset-allocation",
    "hono",
    "rest-api"
  ],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsc -b --emitDeclarationOnly",
    "lint": "eslint .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@vibedcoder/invespro-core": "workspace:*",
    "@vibedcoder/invespro-types": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@invespro/eslint-config": "workspace:*",
    "@invespro/tsconfig": "workspace:*",
    "hono": "^4.12.25",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "hono": "^4.7.11"
  }
}
