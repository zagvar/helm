{
  "name": "@vibedcoder/invespro-cli",
  "version": "0.1.3",
  "description": "CLI for investment profiling and portfolio allocation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vibedcoder/invespro.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/vibedcoder/invespro/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/vibedcoder/invespro/issues"
  },
  "keywords": [
    "investment",
    "risk-profile",
    "asset-allocation",
    "cli",
    "csv",
    "json"
  ],
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "invespro": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsx --tsconfig tsconfig.dev.json src/index.ts",
    "typecheck": "tsc -b --emitDeclarationOnly",
    "lint": "eslint .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "@vibedcoder/invespro-core": "^0.2.1",
    "@vibedcoder/invespro-types": "^0.1.1",
    "citty": "^0.2.2",
    "csv-stringify": "^6.8.0"
  },
  "devDependencies": {
    "@invespro/eslint-config": "workspace:*",
    "@invespro/tsconfig": "workspace:*",
    "@types/node": "^25.9.3",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
