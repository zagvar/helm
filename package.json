{
  "name": "invespro",
  "private": true,
  "version": "0.0.0",
  "description": "Rules-based investment profiling and portfolio allocation engine",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vibedcoder/invespro.git"
  },
  "homepage": "https://github.com/vibedcoder/invespro#readme",
  "bugs": {
    "url": "https://github.com/vibedcoder/invespro/issues"
  },
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "demo:dev": "pnpm --filter @invespro/demo dev",
    "demo:build": "pnpm --filter @invespro/demo... build",
    "test": "pnpm -r test",
    "typecheck": "tsc -b --emitDeclarationOnly",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "keywords": [
    "investment",
    "risk-profile",
    "asset-allocation",
    "portfolio",
    "zen-engine",
    "gorules",
    "hono",
    "cli"
  ],
  "author": "zayau",
  "type": "module",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@changesets/config": "^3.1.4",
    "@types/node": "^25.9.3",
    "eslint": "^10.4.1",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
